# ─────────────────────────────────────────────────────────────────────────────
# TimeClock — Docker environment configuration
# Copy this file to .env.docker and fill in your values before running start.sh
# ─────────────────────────────────────────────────────────────────────────────

# Database password — choose something strong (no spaces or @ symbols)
DB_PASSWORD=changeme_pick_a_strong_password

# Session signing key — generate one by running:
#   Linux/Mac:  openssl rand -hex 32
#   Windows:    (any long random string works)
SESSION_SECRET=replace_with_a_long_random_string

# ── Clerk authentication keys ──────────────────────────────────────────────────
# 1. Go to https://clerk.com and sign in (free account)
# 2. Create a new application (enable Email/Password and Google)
# 3. Go to API Keys in the left sidebar
# 4. Copy the Secret Key and Publishable Key below
# 5. In Clerk dashboard → Domains, add your server's IP or domain
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Port to expose the app on your network (default: 80)
# Change to 8080 or another port if 80 is already in use
APP_PORT=80
